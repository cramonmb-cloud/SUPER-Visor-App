rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // CAMBIO: Permitir lectura/escritura a todos (Modo de Desarrollo)
      // Esto elimina el error "Missing or insufficient permissions"
      // Cuando la app esté lista para producción, cambia esto a: if request.auth != null;
      allow read, write: if true;
    }
  }
}